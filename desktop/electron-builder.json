{
  "appId": "com.prepai.desktop",
  "productName": "PrepAI",
  "directories": {
    "output": "release"
  },
  "files": [
    "main.js",
    "preload.js",
    "package.json",
    "assets/**/*",
    {
      "from": "../client/dist",
      "to": "dist",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "assets/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "PrepAI",
    "artifactName": "InterviewAISetup.exe",
    "uninstallDisplayName": "PrepAI Uninstaller"
  }
}
